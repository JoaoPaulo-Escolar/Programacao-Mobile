Algoritmo "Exercício 4"
// 
//  
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 13/02/2026
Var
// Seçăo de Declaraçőes das variáveis 
base, altura, area: inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
escreva("informe a base:")
leia(base)
escreva("informe a altura:")
leia(altura)
area <- base * altura
escreva("sua area é:", area)
Fimalgoritmo